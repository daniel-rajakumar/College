extends layouts/layout

block content
  .card-header
    h1 Delete Contact
    h4= `${contact.first} ${contact.last}`
  .card-body
    p Are you sure you want to delete this contact?
    form(action=`/:${contact.id}/delete`, method='post')
      .btn-group.d-none.d-lg-block
        button.btn.btn-danger.w-50(type='submit') Yes, delete this contact
        a.btn.btn-primary.w-50(href=`/${contact.id}`) No, go back
      .d-lg-none
        button.btn.btn-danger.w-100(type='submit') Yes, delete this contact
        a.btn.btn-primary.w-100.mt-2(href=`/${contact.id}`) No, go back