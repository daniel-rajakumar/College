<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/round_result_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvRoundResultTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Round Results"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvRoundWinner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Winner: Human (by COVER)"
        android:textSize="18sp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvRoundResultTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvRoundPoints"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Points this round: +15"
        android:textSize="16sp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvRoundWinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvRoundTotals"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Total scores — Human: 25 | Computer: 10"
        android:textSize="16sp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvRoundPoints"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnPlayAgain"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Play Next Round"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvRoundTotals"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnQuitTournament"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Quit Tournament"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnPlayAgain"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
