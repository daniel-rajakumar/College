<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/game_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvGameTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Canoga — Round"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textAlignment="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scores -->
    <TextView
        android:id="@+id/tvScores"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Human: 0  |  Computer: 0"
        android:textSize="16sp"
        android:paddingTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvGameTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dice result -->
    <TextView
        android:id="@+id/tvDice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Dice: -"
        android:textSize="16sp"
        android:paddingTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvScores"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status line -->
    <TextView
        android:id="@+id/tvGameStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Welcome to Canoga!"
        android:textSize="16sp"
        android:paddingTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvDice"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BOARD AREA (this will stretch) -->
    <com.example.oplcanoga.view.BoardView
        android:id="@+id/boardView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:background="#FFEFEFEF"
        app:layout_constraintTop_toBottomOf="@id/tvGameStatus"
        app:layout_constraintBottom_toTopOf="@id/layoutControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Controls + move selection -->
    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toTopOf="@id/layoutLog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Dice buttons -->
        <!-- Dice buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRollOneDie"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Roll 1 Die" />

            <Button
                android:id="@+id/btnRollDie"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Roll 2 Dice" />

            <Button
                android:id="@+id/btnInputDie"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Input Die" />

            <Button
                android:id="@+id/btnSaveGame"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save Game" />
        </LinearLayout>


        <!-- Move selection -->
        <TextView
            android:id="@+id/tvMoveLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose a legal move:"
            android:paddingTop="8dp" />

        <Spinner
            android:id="@+id/spinnerMoves"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Confirm / Help -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <Button
                android:id="@+id/btnConfirmMove"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Confirm" />

            <Button
                android:id="@+id/btnHelp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Help" />
        </LinearLayout>
    </LinearLayout>

    <!-- Log area (fixed small height at bottom) -->
    <LinearLayout
        android:id="@+id/layoutLog"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:orientation="vertical"
        android:paddingTop="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvLogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Game Log"
            android:textStyle="bold" />

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:padding="4dp" />
        </ScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
