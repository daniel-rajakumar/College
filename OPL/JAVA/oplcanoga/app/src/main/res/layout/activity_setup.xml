<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/setup_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvSetupTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="New Game Setup"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvBoardSizeLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Choose board size:"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSetupTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <RadioGroup
        android:id="@+id/rgBoardSize"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvBoardSizeLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RadioButton
            android:id="@+id/rbSize9"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9" />

        <RadioButton
            android:id="@+id/rbSize10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10" />

        <RadioButton
            android:id="@+id/rbSize11"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="11" />
    </RadioGroup>

    <TextView
        android:id="@+id/tvRollOffTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Roll-off: who goes first?"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/rgBoardSize"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/llRollOffDice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvRollOffTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvHumanDice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Human: -"
            android:textAlignment="center"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvComputerDice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Computer: -"
            android:textAlignment="center"
            android:textSize="16sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvRollOffResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Press Roll to decide who goes first."
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/llRollOffDice"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnRollOff"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Roll Dice"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvRollOffResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnStartGame"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Start Game"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnRollOff"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
