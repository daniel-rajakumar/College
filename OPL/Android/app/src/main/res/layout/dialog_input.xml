<?xml version="1.0" encoding="utf-8"?>
            <LinearLayout
                xmlns:android="http://schemas.android.com/apk/res/android"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Section for Dice 1 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Dice 1:"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <ToggleButton
                        android:id="@+id/dice1_btn1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="I"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <ToggleButton
                        android:id="@+id/dice1_btn2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="II"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <ToggleButton
                        android:id="@+id/dice1_btn3"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="III"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <ToggleButton
                        android:id="@+id/dice1_btn4"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="IV"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <ToggleButton
                        android:id="@+id/dice1_btn5"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="V"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <ToggleButton
                        android:id="@+id/dice1_btn6"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="VI"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Section for Dice 2 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Dice 2:"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ToggleButton
                        android:id="@+id/dice2_btn1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="I"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <ToggleButton
                        android:id="@+id/dice2_btn2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="II"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <ToggleButton
                        android:id="@+id/dice2_btn3"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="III"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <ToggleButton
                        android:id="@+id/dice2_btn4"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="IV"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <ToggleButton
                        android:id="@+id/dice2_btn5"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="V"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <ToggleButton
                        android:id="@+id/dice2_btn6"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@drawable/circle_creator"
                        android:textOff="VI"
                        android:textOn=""
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />
                </LinearLayout>

            </LinearLayout>