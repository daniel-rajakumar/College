<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Canoga"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scoreboard -->
    <LinearLayout
        android:id="@+id/scoreBoardLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/tvHumanScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Your Score: 0"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvComputerScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Computer Score: 0"
            android:textSize="18sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Turn Indicator -->
    <TextView
        android:id="@+id/tvTurnIndicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Your Turn"
        android:textSize="18sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/scoreBoardLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Human Board View -->
    <TextView
        android:id="@+id/tvHumanBoard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Your Board: [ ] [ ] [ ] [ ] [ ]"
        android:textSize="16sp"
        android:padding="8dp"
        android:background="@drawable/board_background"
        app:layout_constraintTop_toBottomOf="@id/tvTurnIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Computer Board View -->
    <TextView
        android:id="@+id/tvComputerBoard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Computer Board: [ ] [ ] [ ] [ ] [ ]"
        android:textSize="16sp"
        android:padding="8dp"
        android:background="@drawable/board_background"
        app:layout_constraintTop_toBottomOf="@id/tvHumanBoard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Dice Section -->
    <LinearLayout
        android:id="@+id/diceLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvComputerBoard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <ImageView
            android:id="@+id/ivDice1"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/dice_1"
            android:contentDescription="Dice 1" />

        <ImageView
            android:id="@+id/ivDice2"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/dice_2"
            android:contentDescription="Dice 2"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tvDiceSum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sum: 0"
            android:textSize="18sp"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/diceLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnRoll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Roll Dice" />

        <Button
            android:id="@+id/btnInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Input Move"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save Game"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnHelp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Help"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Game Log (ScrollView) -->
    <ScrollView
        android:id="@+id/scrollViewGameLog"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/darker_gray"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/buttonLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/tvGameLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Game Log:"
            android:textColor="@android:color/white" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
